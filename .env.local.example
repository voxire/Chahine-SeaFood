# Copy to .env.local for local dev. Never commit .env.local.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub PAT — used by Claude to push/pull on Abed's behalf. See CLAUDE.md §5.2.
# Classic PAT with `repo` scope, or fine-grained with Contents: read/write on this repo.
GH_TOKEN=

# Sanity — fill when the project is created
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_WEBHOOK_SECRET=

# Analytics — pick one
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=chahineseafood.com
